{
  "name": "reearth-serve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "reearth-serve": "./bin/reearth-serve.mjs"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "deploy": "bash scripts/deploy.sh",
    "init:dev-secrets": "bash scripts/init-dev-secrets.sh",
    "typegen": "wrangler types && react-router typegen",
    "check": "npm run typecheck && npm run test",
    "typecheck": "tsc -b",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:dev": "bash scripts/e2e.sh",
    "cli": "tsx cli/index.ts --",
    "gen:compressible": "tsx scripts/gen-compressible.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.1",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.3",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "aws4fetch": "^1.0.20",
    "commander": "^14.0.3",
    "hono": "^4.7.0",
    "hono-openapi": "^1.3.0",
    "isbot": "^5.1.35",
    "jose": "^6.2.1",
    "open": "^11.0.0",
    "openapi-types": "^12.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@cloudflare/workers-types": "^4.20250310.0",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mime-db": "^1.43.6",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "mime-db": "^1.54.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0",
    "wrangler": "^4.73.0"
  }
}
